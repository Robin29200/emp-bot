# Copie ce fichier en ".env" et remplis les valeurs

# Token du bot (Discord Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# Client ID de l'application (Discord Developer Portal > General Information > Application ID)
CLIENT_ID=

# ID de ton serveur Discord (active le mode développeur dans Discord,
# puis clic droit sur le serveur > Copier l'identifiant)
GUILD_ID=

# Port du petit serveur API local (utilisé plus tard pour relier le site)
PORT=3000

# ID du groupe Roblox de l'EMP (dans l'URL du groupe : roblox.com/groups/XXXXXXX/nom)
ROBLOX_GROUP_ID=
